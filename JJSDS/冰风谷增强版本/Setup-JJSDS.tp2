COPY_EXISTING ~sds#fya.spl~ ~override~
    WRITE_SHORT   0x98 ~%sds#fy%~

COPY_EXISTING ~sds#sda.spl~ ~override~
    WRITE_SHORT   0x98 ~%sds#sd%~
    WRITE_SHORT   0xc0 ~%sds#sd%~
    WRITE_SHORT   0xe8 ~%sds#sd%~

COPY_EXISTING ~sds#mqa.spl~ ~override~
    WRITE_SHORT   0x98 ~%sds#mq%~
    WRITE_SHORT   0xc0 ~%sds#mq%~
    WRITE_SHORT   0xe8 ~%sds#mq%~

