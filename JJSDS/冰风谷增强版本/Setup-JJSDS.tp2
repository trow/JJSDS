    WRITE_SHORT   0x98 ~%sds#al%~
	
////顕固塀岼匍尫崙///

COPY_EXISTING ~ABCLASRQ.2da~ ~override~	

SET_2DA_ENTRY 58 1 1 ~18~
SET_2DA_ENTRY 58 2 1 ~18~
